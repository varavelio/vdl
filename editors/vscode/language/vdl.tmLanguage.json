{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "vdl",
  "scopeName": "source.vdl",
  "fileTypes": ["vdl"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#docstrings" },
    { "include": "#annotations" },
    { "include": "#includes" },
    { "include": "#type-declarations" },
    { "include": "#enum-declarations" },
    { "include": "#const-declarations" },
    { "include": "#data-literals" },
    { "include": "#field-types" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.vdl",
          "match": "//.*$"
        },
        {
          "name": "comment.block.vdl",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "docstrings": {
      "name": "string.quoted.docstring.multi.vdl",
      "begin": "\"\"\"",
      "end": "\"\"\"",
      "patterns": [
        {
          "name": "markup.underline.link.vdl",
          "match": "\\./[a-zA-Z0-9_\\-\\./]+\\.md"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.vdl",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.vdl",
          "match": "\\\\."
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "name": "meta.annotation.vdl",
          "begin": "(@[a-zA-Z_][a-zA-Z0-9_]*)\\s*(\\()",
          "beginCaptures": {
            "1": { "name": "storage.type.annotation.vdl" },
            "2": { "name": "punctuation.definition.parameters.begin.vdl" }
          },
          "end": "\\)",
          "endCaptures": {
            "0": { "name": "punctuation.definition.parameters.end.vdl" }
          },
          "patterns": [
            { "include": "#comments" },
            { "include": "#docstrings" },
            { "include": "#data-literals" },
            { "include": "#operators" }
          ]
        },
        {
          "name": "storage.type.annotation.vdl",
          "match": "@[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "includes": {
      "patterns": [
        {
          "name": "meta.include.vdl",
          "match": "\\b(include)\\b\\s*(\"(?:\\\\.|[^\"])*\")",
          "captures": {
            "1": { "name": "keyword.control.include.vdl" },
            "2": { "name": "string.quoted.double.vdl" }
          }
        }
      ]
    },
    "type-declarations": {
      "patterns": [
        {
          "name": "meta.declaration.type.object.vdl",
          "begin": "\\b(type)\\b\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*(\\{)",
          "beginCaptures": {
            "1": { "name": "keyword.control.declaration.vdl" },
            "2": { "name": "entity.name.type.declaration.vdl" },
            "3": { "name": "punctuation.section.braces.begin.vdl" }
          },
          "end": "\\}",
          "endCaptures": {
            "0": { "name": "punctuation.section.braces.end.vdl" }
          },
          "patterns": [{ "include": "#type-body" }]
        },
        {
          "name": "meta.declaration.type.alias.vdl",
          "begin": "\\b(type)\\b\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "beginCaptures": {
            "1": { "name": "keyword.control.declaration.vdl" },
            "2": { "name": "entity.name.type.declaration.vdl" }
          },
          "end": "$",
          "patterns": [
            { "include": "#comments" },
            { "include": "#field-types" },
            { "include": "#operators" }
          ]
        }
      ]
    },
    "enum-declarations": {
      "patterns": [
        {
          "name": "meta.declaration.enum.vdl",
          "begin": "\\b(enum)\\b\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*(\\{)",
          "beginCaptures": {
            "1": { "name": "keyword.control.declaration.vdl" },
            "2": { "name": "entity.name.type.declaration.vdl" },
            "3": { "name": "punctuation.section.braces.begin.vdl" }
          },
          "end": "\\}",
          "endCaptures": {
            "0": { "name": "punctuation.section.braces.end.vdl" }
          },
          "patterns": [
            { "include": "#comments" },
            { "include": "#docstrings" },
            { "include": "#annotations" },
            { "include": "#type-spreads" },
            { "include": "#enum-members" },
            { "include": "#data-literals" },
            { "include": "#operators" }
          ]
        }
      ]
    },
    "const-declarations": {
      "patterns": [
        {
          "name": "meta.declaration.constant.object.vdl",
          "begin": "\\b(const)\\b\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*(=)\\s*(\\{)",
          "beginCaptures": {
            "1": { "name": "keyword.control.declaration.vdl" },
            "2": { "name": "variable.other.constant.declaration.vdl" },
            "3": { "name": "keyword.operator.assignment.vdl" },
            "4": { "name": "punctuation.section.braces.begin.vdl" }
          },
          "end": "\\}",
          "endCaptures": {
            "0": { "name": "punctuation.section.braces.end.vdl" }
          },
          "patterns": [{ "include": "#data-object-body" }]
        },
        {
          "name": "meta.declaration.constant.array.vdl",
          "begin": "\\b(const)\\b\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*(=)\\s*(\\[)",
          "beginCaptures": {
            "1": { "name": "keyword.control.declaration.vdl" },
            "2": { "name": "variable.other.constant.declaration.vdl" },
            "3": { "name": "keyword.operator.assignment.vdl" },
            "4": { "name": "punctuation.section.brackets.begin.vdl" }
          },
          "end": "\\]",
          "endCaptures": {
            "0": { "name": "punctuation.section.brackets.end.vdl" }
          },
          "patterns": [{ "include": "#data-literals" }]
        },
        {
          "name": "meta.declaration.constant.scalar.vdl",
          "match": "\\b(const)\\b\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*(=)",
          "captures": {
            "1": { "name": "keyword.control.declaration.vdl" },
            "2": { "name": "variable.other.constant.declaration.vdl" },
            "3": { "name": "keyword.operator.assignment.vdl" }
          }
        }
      ]
    },
    "type-body": {
      "patterns": [
        { "include": "#comments" },
        { "include": "#docstrings" },
        { "include": "#annotations" },
        { "include": "#type-spreads" },
        { "include": "#inline-object-fields" },
        { "include": "#field-members" },
        { "include": "#field-names" },
        { "include": "#field-types" },
        { "include": "#operators" }
      ]
    },
    "inline-object-fields": {
      "patterns": [
        {
          "name": "meta.field.object.vdl",
          "begin": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(\\?)?\\s*(\\{)",
          "beginCaptures": {
            "1": { "name": "variable.other.property.vdl" },
            "2": { "name": "keyword.operator.optional.vdl" },
            "3": { "name": "punctuation.section.braces.begin.vdl" }
          },
          "end": "\\}",
          "endCaptures": {
            "0": { "name": "punctuation.section.braces.end.vdl" }
          },
          "patterns": [{ "include": "#type-body" }]
        }
      ]
    },
    "field-members": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(\\?)?(\\s+)(map)\\b",
          "captures": {
            "1": { "name": "variable.other.property.vdl" },
            "2": { "name": "keyword.operator.optional.vdl" },
            "4": { "name": "storage.type.container.vdl" }
          }
        },
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(\\?)?(\\s+)(string|int|float|bool|datetime)\\b",
          "captures": {
            "1": { "name": "variable.other.property.vdl" },
            "2": { "name": "keyword.operator.optional.vdl" },
            "4": { "name": "storage.type.primitive.vdl" }
          }
        },
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(\\?)?(\\s+)([A-Z][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "variable.other.property.vdl" },
            "2": { "name": "keyword.operator.optional.vdl" },
            "4": { "name": "entity.name.type.reference.vdl" }
          }
        }
      ]
    },
    "field-names": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(\\?)?(?=\\s+(?:[a-zA-Z_][a-zA-Z0-9_]*|map\\b|\\{))",
          "captures": {
            "1": { "name": "variable.other.property.vdl" },
            "2": { "name": "keyword.operator.optional.vdl" }
          }
        }
      ]
    },
    "field-types": {
      "patterns": [
        {
          "name": "storage.type.primitive.vdl",
          "match": "\\b(string|int|float|bool|datetime)\\b"
        },
        {
          "name": "storage.type.container.vdl",
          "match": "\\bmap\\b"
        },
        {
          "name": "entity.name.type.reference.vdl",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "enum-members": {
      "patterns": [
        {
          "name": "variable.other.enummember.vdl",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b(?=\\s*(?:=|$|//|/\\*))"
        }
      ]
    },
    "type-spreads": {
      "patterns": [
        {
          "match": "(\\.\\.\\.)([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.operator.spread.vdl" },
            "2": { "name": "entity.name.type.reference.vdl" }
          }
        }
      ]
    },
    "object-spreads": {
      "patterns": [
        {
          "match": "(\\.\\.\\.)([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.operator.spread.vdl" },
            "2": { "name": "variable.other.constant.vdl" }
          }
        }
      ]
    },
    "data-literals": {
      "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#constants-language" },
        { "include": "#constants-numeric" },
        { "include": "#enum-member-references" },
        { "include": "#data-objects" },
        { "include": "#data-arrays" },
        { "include": "#constant-references" },
        { "include": "#operators" }
      ]
    },
    "data-object-body": {
      "patterns": [
        { "include": "#comments" },
        { "include": "#object-spreads" },
        { "include": "#data-object-keys" },
        { "include": "#strings" },
        { "include": "#constants-language" },
        { "include": "#constants-numeric" },
        { "include": "#enum-member-references" },
        { "include": "#data-objects" },
        { "include": "#data-arrays" },
        { "include": "#constant-references" },
        { "include": "#operators" }
      ]
    },
    "data-objects": {
      "patterns": [
        {
          "name": "meta.object-literal.vdl",
          "begin": "\\{",
          "beginCaptures": {
            "0": { "name": "punctuation.section.braces.begin.vdl" }
          },
          "end": "\\}",
          "endCaptures": {
            "0": { "name": "punctuation.section.braces.end.vdl" }
          },
          "patterns": [{ "include": "#data-object-body" }]
        }
      ]
    },
    "data-arrays": {
      "patterns": [
        {
          "name": "meta.array-literal.vdl",
          "begin": "\\[",
          "beginCaptures": {
            "0": { "name": "punctuation.section.brackets.begin.vdl" }
          },
          "end": "\\]",
          "endCaptures": {
            "0": { "name": "punctuation.section.brackets.end.vdl" }
          },
          "patterns": [{ "include": "#data-literals" }]
        }
      ]
    },
    "data-object-keys": {
      "patterns": [
        {
          "name": "variable.other.property.vdl",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b(?=\\s+(?:\"|[0-9]+(?:\\.[0-9]+)?\\b|true\\b|false\\b|\\{|\\[|[a-zA-Z_][a-zA-Z0-9_]*(?:\\.[a-zA-Z_][a-zA-Z0-9_]*)?))"
        }
      ]
    },
    "constant-references": {
      "patterns": [
        {
          "name": "variable.other.constant.vdl",
          "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "enum-member-references": {
      "patterns": [
        {
          "match": "\\b([A-Z][a-zA-Z0-9_]*)(\\.)([A-Z][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "entity.name.type.reference.vdl" },
            "2": { "name": "punctuation.accessor.dot.vdl" },
            "3": { "name": "variable.other.enummember.vdl" }
          }
        }
      ]
    },
    "constants-language": {
      "patterns": [
        {
          "name": "constant.language.boolean.vdl",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "constants-numeric": {
      "patterns": [
        {
          "name": "constant.numeric.float.vdl",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.vdl",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.spread.vdl",
          "match": "\\.\\.\\."
        },
        {
          "name": "keyword.operator.optional.vdl",
          "match": "\\?"
        },
        {
          "name": "keyword.operator.assignment.vdl",
          "match": "="
        },
        {
          "name": "punctuation.accessor.dot.vdl",
          "match": "\\."
        },
        {
          "name": "punctuation.section.braces.begin.vdl",
          "match": "\\{"
        },
        {
          "name": "punctuation.section.braces.end.vdl",
          "match": "\\}"
        },
        {
          "name": "punctuation.section.brackets.begin.vdl",
          "match": "\\["
        },
        {
          "name": "punctuation.section.brackets.end.vdl",
          "match": "\\]"
        },
        {
          "name": "punctuation.definition.parameters.begin.vdl",
          "match": "\\("
        },
        {
          "name": "punctuation.definition.parameters.end.vdl",
          "match": "\\)"
        }
      ]
    }
  }
}
