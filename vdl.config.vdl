const config = {
  version 1

  hooks {
    postGenerate ["go -C toolchain fmt ./... > /dev/null"]
  }

  plugins [
    {
      src "varavelio/vdl-plugin-go@2b01c8e"
      schema "./schemas/ir.vdl"
      outDir "./toolchain/internal/core/ir/irtypes"
      options {
        package "irtypes"
        genMeta "no"
      }
    }
    {
      src "varavelio/vdl-plugin-go@2b01c8e"
      schema "./schemas/plugin.vdl"
      outDir "./toolchain/internal/codegen/plugintypes"
      options {
        package "plugintypes"
        genMeta "no"
      }
    }
    {
      src "varavelio/vdl-plugin-go@2b01c8e"
      schema "./schemas/config_file.vdl"
      outDir "./toolchain/internal/codegen/configtypes"
      options {
        package "configtypes"
        genMeta "no"
      }
    }
    {
      src "varavelio/vdl-plugin-go@2b01c8e"
      schema "./schemas/lock_file.vdl"
      outDir "./toolchain/internal/codegen/locktypes"
      options {
        package "locktypes"
        genMeta "no"
      }
    }
  ]
}
