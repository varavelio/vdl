@rpc type catalog {
@proc create_product {
input { product_id string }
output { ok bool }
}

@proc get_product {
input { id string }
output {
""" doc """
result string
}
}
}

// >>>>

@rpc
type Catalog {
  @proc
  createProduct {
    input {
      productId string
    }
    output {
      ok bool
    }
  }

  @proc
  getProduct {
    input {
      id string
    }
    output {
      """ doc """
      result string
    }
  }
}
