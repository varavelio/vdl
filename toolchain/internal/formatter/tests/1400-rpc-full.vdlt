@rpc type catalog {
"""
  # Product Lifecycle
  Endpoints for creating and managing products.
"""
@proc create_product {
input { product Product }
output {
success bool
product_id string
}
}

"""
  Subscribes to new messages.
"""
@stream new_messages {
input { channel_id string }
output { text string }
}
}

// >>>>

@rpc
type Catalog {
  """
  # Product Lifecycle
  Endpoints for creating and managing products.
  """
  @proc
  createProduct {
    input {
      product Product
    }
    output {
      success bool
      productId string
    }
  }

  """
  Subscribes to new messages.
  """
  @stream
  newMessages {
    input {
      channelId string
    }
    output {
      text string
    }
  }
}
