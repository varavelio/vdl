type my_type {
  field_one string
  FieldTwo int
  FIELD_THREE bool
}

enum order_status {
  pending
  IN_PROGRESS
  completed_fully
}

@deprecated const MAX_PAGE_SIZE = 100
@pattern const user_event_subject = "events.users.{userId}"

@rpc type my_service {
  @proc get_user {
    input {
      user_id string
    }
    output {
      USER_DATA my_type
    }
