include "./foo.vdl"
include "./bar.vdl"

""" ./docs/welcome.md """

@pattern const user_event_subject="events.users.{userId}.{eventType}"

const API_VERSION = "1.0.0"
const RETRY_COUNT=3

enum order_status {
pending
processing
delivered = "delivered"
}

@rpc type catalog_service {
""" Product operations """
@proc list_products {
input {
page int
limit int
}
output {
items product[]
total int
}
}

@stream watch_products {
input {
filter? string
}
output {
event string
at datetime
}
}
}

type audit_metadata {
created_at datetime
updated_at datetime
}

type product {
...audit_metadata
id string
name string
status order_status
tags string[]
meta map[string]
config {
enabled bool
retries int
}
}

const default_config = {
...base_config
enabled true
status order_status.pending
timeouts [100 250 500]
}

// >>>>

include "./foo.vdl"
include "./bar.vdl"

""" ./docs/welcome.md """

@pattern
const userEventSubject = "events.users.{userId}.{eventType}"

const apiVersion = "1.0.0"
const retryCount = 3

enum OrderStatus {
  Pending
  Processing
  Delivered = "delivered"
}

@rpc
type CatalogService {
  """ Product operations """
  @proc
  listProducts {
    input {
      page int
      limit int
    }
    output {
      items Product[]
      total int
    }
  }

  @stream
  watchProducts {
    input {
      filter? string
    }
    output {
      event string
      at datetime
    }
  }
}

type AuditMetadata {
  createdAt datetime
  updatedAt datetime
}

type Product {
  ...AuditMetadata
  id string
  name string
  status OrderStatus
  tags string[]
  meta map[string]
  config {
    enabled bool
    retries int
  }
}

const defaultConfig = {
  ...baseConfig
  enabled true
  status OrderStatus.Pending
  timeouts [100 250 500]
}
