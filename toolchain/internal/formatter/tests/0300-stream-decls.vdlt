@rpc type service{  @stream user_updates {
input { user_id string }
output { event_name string  created_at datetime[] }
}

@stream heartbeat { output { ok bool }}
}

// >>>>

@rpc
type Service {
  @stream
  UserUpdates {
    input {
      userId string
    }

    output {
      eventName string
      createdAt datetime[]
    }
  }

  @stream
  Heartbeat {
    output {
      ok bool
    }
  }
}
